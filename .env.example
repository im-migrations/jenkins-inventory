# Global Personal Access Token (Code: Read scope). Used for any org without a
# specific entry in AZDO_TOKENS.
AZDO_PAT=your_pat_here

# Comma-separated list of organization names to scan.
AZDO_ORGS=contoso,fabrikam

# Optional per-organization tokens. Two accepted formats:
#   org=pat pairs:  AZDO_TOKENS=contoso=pat1,fabrikam=pat2
#   JSON:           AZDO_TOKENS={"contoso":"pat1","fabrikam":"pat2"}
# Any org not listed here falls back to AZDO_PAT.
AZDO_TOKENS=
